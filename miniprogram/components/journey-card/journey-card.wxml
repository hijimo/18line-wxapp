<!--journey-card.wxml-->
<wxs src="../../utils/oss.wxs" module="oss" />
<view class="journey-section">
  <!-- Empty State -->
  <view wx:if="{{!journeys || journeys.length === 0}}" class="empty-state">
    <view class="empty-state-inner">
      <view class="empty-icon-wrapper">
        <image class="empty-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-target.svg" mode="aspectFit" />
      </view>
      <view class="empty-text-group">
        <text class="empty-title">还没有行程安排</text>
        <text class="empty-desc">创建你的第一段旅程，开启探索之旅</text>
      </view>
      <view class="empty-action" bindtap="onCreateTrip">
        <text class="empty-action-text">创建行程</text>
        <image class="empty-action-arrow" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- Journey Cards -->
  <block wx:else>
    <swiper class="journey-swiper" next-margin="48rpx" previous-margin="0" bindchange="onSwiperChange">
      <swiper-item wx:for="{{journeys}}" wx:key="id">
        <view class="journey-card" bindtap="onCardTap" data-id="{{item.id}}">
          <view class="journey-card-inner">
            <!-- Progress Header -->
            <view class="progress-header">
              <view class="progress-left">
                <text class="progress-title">{{item.title}}</text>
                <view class="progress-date">
                  <image class="icon-calendar" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-calendar.svg" />
                  <text class="progress-date-text">{{item.date}}</text>
                </view>
              </view>
              <view class="progress-right">
                <text class="progress-budget">{{item.budget}}</text>
                <text class="progress-budget-label">TOTAL BUDGET</text>
              </view>
            </view>

            <!-- Day Progress Tracker -->
            <view wx:if="{{item.days && item.days.length > 0}}" class="day-tracker">
              <view class="tracker-line" />
              <view class="tracker-dots">
                <view wx:for="{{item.days}}" wx:key="day" wx:for-item="day" class="day-item {{day.status === 'completed' ? 'day-completed' : day.status === 'active' ? 'day-active' : 'day-upcoming'}}">
                  <view class="day-dot">
                    <image wx:if="{{day.status === 'completed'}}" class="icon-check" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-check.svg" />
                    <text wx:else class="day-number">{{day.number}}</text>
                  </view>
                  <text class="day-label">{{day.label}}</text>
                </view>
              </view>
            </view>

            <!-- Day Empty State -->
            <view wx:if="{{!item.days || item.days.length === 0}}" class="day-empty">
              <view class="day-empty-line" />
              <view class="day-empty-content">
                <text class="day-empty-text">暂无日程安排</text>
                <text class="day-empty-hint">点击进入行程添加每日计划</text>
              </view>
            </view>

            <!-- Current Goal：当天景点数 + 总游玩时间 -->
            <view wx:if="{{item.goalTitle}}" class="current-goal">
              <image class="icon-target" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-target.svg" />
              <view class="goal-text">
                <text class="goal-label">当天目标</text>
                <text class="goal-title">{{item.goalTitle}}</text>
              </view>
            </view>
            <view wx:else class="current-goal current-goal--placeholder">
              <view class="goal-placeholder-icon">
                <image class="icon-target icon-target--placeholder" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-target.svg" />
              </view>
              <view class="goal-text">
                <text class="goal-label">当前目标</text>
                <text class="goal-title goal-title--placeholder">暂未设置探索目标</text>
                <text class="goal-hint">进入行程后添加今天想完成的计划</text>
              </view>
            </view>

            <!-- 目的地影像(左，当天景点首图轮换) + 酒店(右上) + 餐厅(右下) -->
            <view wx:if="{{item.destinationImages && item.destinationImages.length > 0}}" class="location-images">
              <view class="location-main">
                <swiper class="destination-swiper" autoplay="{{item.destinationImages.length > 1}}" circular interval="3500" duration="600" indicator-dots="{{item.destinationImages.length > 1}}" indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#ffffff">
                  <swiper-item wx:for="{{item.destinationImages}}" wx:key="index" wx:for-item="dest">
                    <view class="destination-slide">
                      <image class="location-main-img" src="{{oss.ossResize(dest.image, 350, 384)}}" mode="aspectFill" />
                      <view wx:if="{{dest.blurred}}" class="blur-veil">
                        <text class="blur-veil-text">小秘境</text>
                      </view>
                      <view wx:else class="location-overlay" />
                    </view>
                  </swiper-item>
                </swiper>
              </view>
              <view class="location-side">
                <view class="location-side-item corner-hotel">
                  <image class="location-side-img" src="{{oss.ossResize(item.hotel.image, 210, 180)}}" mode="aspectFill" />
                  <view class="corner-mask" />
                  <view class="corner-info">
                    <text class="corner-label">住</text>
                    <text class="corner-name">{{item.hotel.name}}</text>
                  </view>
                </view>
                <view class="location-side-item corner-dining">
                  <image class="location-side-img" src="{{oss.ossResize(item.restaurant.image, 210, 180)}}" mode="aspectFill" />
                  <view class="corner-mask" />
                  <view class="corner-info">
                    <text class="corner-label">食</text>
                    <text class="corner-name">{{item.restaurant.name}}</text>
                  </view>
                </view>
              </view>
            </view>
            <view wx:else class="location-images location-images--placeholder">
              <view class="location-main location-placeholder-main">
                <view class="location-placeholder-content">
                  <text class="location-placeholder-title">目的地影像待补充</text>
                  <text class="location-placeholder-desc">添加景点后会展示旅途画面</text>
                </view>
              </view>
              <view class="location-side">
                <view class="location-side-item location-placeholder-side">
                  <view class="location-placeholder-dot" />
                </view>
                <view class="location-side-item location-placeholder-side location-placeholder-side--muted">
                  <view class="location-placeholder-dot" />
                </view>
              </view>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </block>
</view>
