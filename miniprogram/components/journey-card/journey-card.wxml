<!--journey-card.wxml-->
<view class="journey-section">
  <view class="journey-header">
    <view class="journey-header-left">
      <text class="journey-heading">我的寻觅之旅</text>
      <text class="journey-subheading">正在进行的奇遇记</text>
    </view>
    <view class="journey-header-btn" bindtap="onViewAll">
      <text class="journey-header-btn-text">全部轨迹</text>
      <image class="icon-chevron" src="/assets/images/icon-chevron-right.svg" />
    </view>
  </view>

  <swiper class="journey-swiper" next-margin="48rpx" previous-margin="0">
    <swiper-item wx:for="{{journeys}}" wx:key="id">
      <view class="journey-card">
        <view class="journey-card-inner">
          <!-- Progress Header -->
          <view class="progress-header">
            <view class="progress-left">
              <text class="progress-title">{{item.title}}</text>
              <view class="progress-date">
                <image class="icon-calendar" src="/assets/images/icon-calendar.svg" />
                <text class="progress-date-text">{{item.date}}</text>
              </view>
            </view>
            <view class="progress-right">
              <text class="progress-budget">{{item.budget}}</text>
              <text class="progress-budget-label">TOTAL BUDGET</text>
            </view>
          </view>

          <!-- Day Progress Tracker -->
          <view class="day-tracker">
            <view class="tracker-line" />
            <view class="tracker-dots">
              <view wx:for="{{item.days}}" wx:key="day" wx:for-item="day" class="day-item {{day.status === 'completed' ? 'day-completed' : day.status === 'active' ? 'day-active' : 'day-upcoming'}}">
                <view class="day-dot">
                  <image wx:if="{{day.status === 'completed'}}" class="icon-check" src="/assets/images/icon-check.svg" />
                  <text wx:else class="day-number">{{day.number}}</text>
                </view>
                <text class="day-label">{{day.label}}</text>
              </view>
            </view>
          </view>

          <!-- Current Goal -->
          <view class="current-goal">
            <image class="icon-target" src="/assets/images/icon-target.svg" />
            <view class="goal-text">
              <text class="goal-label">当前目标</text>
              <text class="goal-title">{{item.currentGoal}}</text>
            </view>
          </view>

          <!-- Location Images -->
          <view class="location-images">
            <view class="location-main">
              <image class="location-main-img" src="{{item.locations[0].image}}" mode="aspectFill" />
              <view class="location-overlay" />
            </view>
            <view class="location-side">
              <view class="location-side-item">
                <image class="location-side-img" src="{{item.locations[1].image}}" mode="aspectFill" />
              </view>
              <view class="location-side-item">
                <image class="location-side-img" src="{{item.locations[2].image}}" mode="aspectFill" />
              </view>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>
  </swiper>
</view>