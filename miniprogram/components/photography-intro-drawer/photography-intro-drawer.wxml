<base-drawer show="{{show}}" height="75vh" bind:close="onClose">
  <view class="intro-drawer">
    <!-- Cover Image -->
    <image
      wx:if="{{data.attachments && data.attachments.length > 0}}"
      class="cover-image"
      src="{{data.attachments[0].url}}"
      mode="aspectFill"
      lazy-load
    />

    <view class="intro-body">
      <!-- Name -->
      <text class="intro-name">{{data.nickname}}</text>

      <!-- Meta Tags -->
      <view class="meta-row">
        <text wx:if="{{data.equipment}}" class="meta-tag">{{data.equipment}}</text>
        <text wx:if="{{data.recommendRating}}" class="meta-tag">推荐指数 {{data.recommendRating}}</text>
      </view>

      <!-- Price -->
      <view class="info-row">
        <text wx:if="{{data.price}}" class="info-price">¥{{data.price}}</text>
      </view>

      <!-- Contact -->
      <view wx:if="{{data.contactInfo}}" class="contact-row">
        <text class="contact-label">联系方式:</text>
        <text class="contact-text">{{data.contactInfo}}</text>
      </view>

      <!-- Introduction -->
      <view wx:if="{{data.introduction}}" class="intro-section">
        <text class="section-title">摄影师介绍</text>
        <text class="section-content">{{data.introduction}}</text>
      </view>
    </view>
  </view>
</base-drawer>
