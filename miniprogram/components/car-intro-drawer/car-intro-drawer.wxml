<base-drawer
  show="{{show}}"
  height="86vh"
  panel-radius="80rpx 80rpx 0 0"
  panel-background="#f9faf4"
  handle-background="rgba(194, 200, 192, 0.3)"
  bind:close="onClose"
>
  <view class="car-intro">
    <view class="car-intro__hero">
      <view class="car-intro__heading">
        <view class="car-intro__title-block">
          <text class="car-intro__title">{{viewModel.title}}</text>
          <view class="car-intro__meta">
            <text wx:if="{{viewModel.subtitleText}}" class="car-intro__rating">{{viewModel.subtitleText}}</text>
            <text wx:if="{{viewModel.subtitleText && viewModel.costText}}" class="car-intro__dot">•</text>
            <text wx:if="{{viewModel.costText}}" class="car-intro__cost">{{viewModel.costText}}</text>
          </view>
        </view>
        <button
          class="car-intro__share"
          hover-class="car-intro__share--active"
          open-type="share"
          aria-label="分享包车"
        >
          <image class="car-intro__share-icon" src="{{iconUrls.share}}" mode="aspectFit" />
        </button>
      </view>

      <view wx:if="{{viewModel.hasGallery}}" class="car-intro__gallery">
        <view class="car-intro__gallery-main" bindtap="onPreviewImageTap" data-index="0">
          <image class="car-intro__image" src="{{viewModel.images[0]}}" mode="aspectFill" lazy-load />
          <view class="car-intro__image-label">
            <text>Travel Car</text>
          </view>
        </view>
        <view wx:if="{{viewModel.images.length > 1}}" class="car-intro__gallery-side">
          <image class="car-intro__thumb" src="{{viewModel.images[1]}}" mode="aspectFill" lazy-load bindtap="onPreviewImageTap" data-index="1" />
          <view wx:if="{{viewModel.images.length > 2}}" class="car-intro__thumb-wrap" bindtap="onPreviewImageTap" data-index="2">
            <image class="car-intro__thumb" src="{{viewModel.images[2]}}" mode="aspectFill" lazy-load />
            <view class="car-intro__photo-mask">
              <text>{{viewModel.photoCountText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="car-intro__gallery car-intro__gallery--empty">
        <text class="car-intro__empty-mark">18</text>
        <text class="car-intro__empty-text">Private Ride</text>
      </view>
    </view>

    <view class="car-intro__content">
      <view wx:if="{{viewModel.attractionName}}" class="car-intro__section">
        <text class="car-intro__section-label">LOCATION</text>
        <view class="car-intro__location-row">
          <image class="car-intro__location-icon" src="{{iconUrls.location}}" mode="aspectFit" />
          <text class="car-intro__location-text">{{viewModel.attractionName}}</text>
        </view>
      </view>

      <view wx:if="{{viewModel.serviceTags.length}}" class="car-intro__section">
        <text class="car-intro__section-label">VEHICLE</text>
        <view class="car-intro__pills">
          <text wx:for="{{viewModel.serviceTags}}" wx:key="*this" class="car-intro__pill">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{viewModel.profileTags.length}}" class="car-intro__section">
        <text class="car-intro__section-label">DRIVER</text>
        <view class="car-intro__pills">
          <text wx:for="{{viewModel.profileTags}}" wx:key="*this" class="car-intro__pill">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{viewModel.contactInfo}}" class="car-intro__section">
        <text class="car-intro__section-label">CONTACT</text>
        <text class="car-intro__body-text">{{viewModel.contactInfo}}</text>
      </view>

      <view wx:if="{{viewModel.description}}" class="car-intro__section">
        <text class="car-intro__section-label">ABOUT</text>
        <text class="car-intro__body-text">{{viewModel.description}}</text>
      </view>

      <view wx:if="{{!viewModel.hasDetails}}" class="car-intro__empty-state">
        <text class="car-intro__empty-state-title">暂无包车详情</text>
        <text class="car-intro__empty-state-text">可先查看行程安排，司机信息更新后会在这里展示。</text>
      </view>
    </view>

    <view class="car-intro__actions">
      <button wx:if="{{source !== 'schedule'}}" class="car-intro__action car-intro__action--secondary" hover-class="car-intro__action--secondary-active" bindtap="onAddTap">
        <text class="car-intro__action-icon">⊞</text>
        <view class="car-intro__action-copy">
          <text class="car-intro__action-text">Add to</text>
          <text class="car-intro__action-text">Itinerary</text>
        </view>
      </button>
      <button class="car-intro__action car-intro__action--primary" hover-class="car-intro__action--primary-active" bindtap="onContactTap">
        <text class="car-intro__action-icon">☎</text>
        <view class="car-intro__action-copy">
          <text class="car-intro__action-text">Contact</text>
          <text class="car-intro__action-text">Driver</text>
        </view>
      </button>
    </view>
  </view>
</base-drawer>
