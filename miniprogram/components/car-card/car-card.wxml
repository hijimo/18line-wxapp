<!--car-card.wxml-->
<view class="card-wrapper">
  <view class="timeline-dot" />
  <view class="card-body">
    <view class="type-label">CHARTERED</view>
    <view class="card-header">
      <view class="card-info">
        <text class="card-name">{{item.nickname}}</text>
        <text class="card-sub">{{item.carModel}}{{item.seatCount ? ' · ' + item.seatCount + '座' : ''}}{{item.price ? ' · ¥' + item.price + '/天' : ''}}</text>
      </view>
      <view class="card-action" bindtap="onDetailTap">
        <text class="action-text">详情</text>
      </view>
    </view>
    <image wx:if="{{item.attachments && item.attachments.length}}" class="card-thumb" src="{{item.attachments[0].fileUrl}}" mode="aspectFill" lazy-load />
  </view>
</view>
