<!--dining-card.wxml-->
<view class="card-wrapper">
  <view class="timeline-dot" />
  <view class="card-body">
    <view class="type-label">{{meal === 'breakfast' ? 'BREAKFAST' : meal === 'lunch' ? 'LUNCH' : 'DINNER'}}</view>
    <view class="card-header">
      <view class="card-info">
        <text class="card-name">{{item.diningName}}</text>
        <text class="card-sub" wx:if="{{item.diningDesc}}">{{item.diningDesc}}</text>
        <text class="card-sub" wx:elif="{{item.avgCost}}">人均 ¥{{item.avgCost}}</text>
      </view>
      <view class="card-action" bindtap="onDetailTap">
        <text class="action-text">详情</text>
      </view>
    </view>
  </view>
</view>
