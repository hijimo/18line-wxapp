<base-drawer
  show="{{show}}"
  height="86vh"
  panel-radius="80rpx 80rpx 0 0"
  panel-background="#f9faf4"
  handle-background="rgba(194, 200, 192, 0.3)"
  bind:close="onClose"
>
  <view class="dining-intro">
    <view class="dining-intro__hero">
      <view class="dining-intro__heading">
        <view class="dining-intro__title-block">
          <text class="dining-intro__title">{{viewModel.title}}</text>
          <view class="dining-intro__meta">
            <text wx:if="{{viewModel.ratingText}}" class="dining-intro__star">★</text>
            <text wx:if="{{viewModel.ratingText}}" class="dining-intro__rating">{{viewModel.ratingText}}</text>
            <text wx:if="{{viewModel.ratingText && viewModel.costText}}" class="dining-intro__dot">•</text>
            <text wx:if="{{viewModel.costText}}" class="dining-intro__cost">{{viewModel.costText}}</text>
          </view>
        </view>
        <button
          class="dining-intro__share"
          hover-class="dining-intro__share--active"
          open-type="share"
          aria-label="分享餐厅"
        >
          <image
            class="dining-intro__share-icon"
            src="{{iconUrls.share}}"
            mode="aspectFit"
          />
        </button>
      </view>

      <view wx:if="{{viewModel.hasGallery}}" class="dining-intro__gallery">
        <view class="dining-intro__gallery-main" bindtap="onPreviewImageTap" data-index="0">
          <image
            class="dining-intro__image"
            src="{{viewModel.images[0]}}"
            mode="aspectFill"
            lazy-load
          />
          <view class="dining-intro__image-label">
            <text>招牌菜</text>
          </view>
        </view>
        <view wx:if="{{viewModel.images.length > 1}}" class="dining-intro__gallery-side">
          <image
            class="dining-intro__thumb"
            src="{{viewModel.images[1]}}"
            mode="aspectFill"
            lazy-load
            bindtap="onPreviewImageTap"
            data-index="1"
          />
          <view wx:if="{{viewModel.images.length > 2}}" class="dining-intro__thumb-wrap" bindtap="onPreviewImageTap" data-index="2">
            <image
              class="dining-intro__thumb"
              src="{{viewModel.images[2]}}"
              mode="aspectFill"
              lazy-load
            />
            <view class="dining-intro__photo-mask">
              <text>{{viewModel.photoCountText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="dining-intro__gallery dining-intro__gallery--empty">
        <text class="dining-intro__empty-mark">18</text>
        <text class="dining-intro__empty-text">地道美食</text>
      </view>
    </view>

    <view class="dining-intro__content">
      <view wx:if="{{viewModel.attractionName}}" class="dining-intro__section">
        <text class="dining-intro__section-label">位置</text>
        <view
          class="dining-intro__location-row"
          hover-class="dining-intro__location-row--active"
          bindtap="onLocationTap"
        >
          <image
            class="dining-intro__location-icon"
            src="{{iconUrls.location}}"
            mode="aspectFit"
          />
          <text class="dining-intro__location-text">{{viewModel.attractionName}}</text>
        </view>
      </view>

      <view wx:if="{{viewModel.dishes.length}}" class="dining-intro__section">
        <text class="dining-intro__section-label">招牌菜品</text>
        <view class="dining-intro__pills">
          <text
            wx:for="{{viewModel.dishes}}"
            wx:key="*this"
            class="dining-intro__pill"
          >{{item}}</text>
        </view>
      </view>

      <view wx:if="{{viewModel.tags.length}}" class="dining-intro__section">
        <text class="dining-intro__section-label">详情</text>
        <view class="dining-intro__pills">
          <text
            wx:for="{{viewModel.tags}}"
            wx:key="*this"
            class="dining-intro__pill"
          >{{item}}</text>
        </view>
      </view>

      <view wx:if="{{viewModel.description}}" class="dining-intro__section">
        <text class="dining-intro__section-label">简介</text>
        <text class="dining-intro__body-text">{{viewModel.description}}</text>
      </view>

      <view wx:if="{{viewModel.pathItems.length}}" class="dining-intro__path-card">
        <text class="dining-intro__path-title">行程路线</text>
        <view class="dining-intro__path-list">
          <view
            wx:for="{{viewModel.pathItems}}"
            wx:key="title"
            class="dining-intro__path-item {{item.active ? 'dining-intro__path-item--active' : ''}}"
          >
            <view class="dining-intro__path-rail">
              <text class="dining-intro__path-icon">{{item.type === 'hotel' ? '▰' : item.type === 'attraction' ? '⌃' : '♨'}}</text>
              <view wx:if="{{index < viewModel.pathItems.length - 1}}" class="dining-intro__path-line" />
            </view>
            <view class="dining-intro__path-copy">
              <text class="dining-intro__path-name">{{item.title}}</text>
              <text class="dining-intro__path-meta">{{item.meta}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{!viewModel.hasDetails}}" class="dining-intro__empty-state">
        <text class="dining-intro__empty-state-title">暂无餐厅详情</text>
        <text class="dining-intro__empty-state-text">可先查看行程安排，餐厅信息更新后会在这里展示。</text>
      </view>
    </view>

    <view class="dining-intro__actions">
      <button
        wx:if="{{source !== 'schedule'}}"
        class="dining-intro__action dining-intro__action--secondary"
        hover-class="dining-intro__action--secondary-active"
        bindtap="onAddTap"
      >
        <image class="dining-intro__action-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-add-itinerary.svg" mode="aspectFit" />
        <view class="dining-intro__action-copy">
          <text class="dining-intro__action-text">添加到行程</text>
          
        </view>
      </button>
      <button
        class="dining-intro__action dining-intro__action--primary"
        hover-class="dining-intro__action--primary-active"
        bindtap="onBookTap"
      >
        <image class="dining-intro__action-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-phone.svg" mode="aspectFit" />
        <view class="dining-intro__action-copy">
          <text class="dining-intro__action-text">预订餐位</text>
          
        </view>
      </button>
    </view>
  </view>
</base-drawer>
