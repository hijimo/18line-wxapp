<!--hotel-card.wxml-->
<view class="card-wrapper">
  <view class="timeline-dot" />
  <view class="card-body">
    <view class="type-label">STAY</view>
    <view class="card-header">
      <view class="card-info">
        <text class="card-name">{{item.accommodationName}}</text>
        <text class="card-sub">{{item.accommodationType}}{{item.priceMin && item.priceMax ? ' · ¥' + item.priceMin + '~' + item.priceMax : ''}}</text>
      </view>
      <view class="card-action" bindtap="onDetailTap">
        <text class="action-text">详情</text>
      </view>
    </view>
  </view>
</view>
