<wxs src="../../utils/oss.wxs" module="oss" />
<view class="page-container">
  <navigation-bar title="创建行程" back="{{true}}" color="black" background="#F9FAF4"></navigation-bar>

  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="main-content">
      <!-- Hero Banner -->
      <view class="hero-section">
        <image class="hero-image" src="{{oss.ossResize('https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/hero-banner-songyang.png', 654, 384)}}" mode="aspectFill" />
        <view class="hero-gradient" />
        <view class="hero-text-container">
          <text class="hero-title">开启一段新旅程</text>
          <text class="hero-subtitle">探索未知的自然之美</text>
        </view>
      </view>

      <!-- Destination -->
      <view class="section">
        <view class="section-header">
          <text class="section-title">要去哪里？</text>
          <text class="section-label">DESTINATION</text>
        </view>
        <picker mode="region" bindchange="onRegionChange" value="{{regionValue}}">
          <view class="search-input">
            <image class="search-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-search.svg" mode="aspectFit" />
            <text class="search-placeholder {{provinceName ? 'search-value' : ''}}">
              {{provinceName ? provinceName + ' ' + cityName + (districtName ? ' ' + districtName : '') : '搜索目的地、城市或景点'}}
            </text>
          </view>
        </picker>
      </view>

      <!-- Date -->
      <view class="section">
        <text class="section-subtitle">出发日期</text>
        <view class="date-card" bindtap="onDateTap">
          <image class="date-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-calendar.svg" mode="aspectFit" />
          <text class="date-value {{startDate ? '' : 'date-placeholder'}}">
            {{startDate ? startDateDisplay + ' — ' + endDateDisplay : '选择出行日期'}}
          </text>
        </view>
      </view>

      <!-- Preferences -->
      <view class="section">
        <view class="section-header-with-icon">
          <image class="section-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-travel-trait.svg" mode="aspectFit" />
          <text class="section-title">旅行偏好</text>
        </view>
        <view class="preference-grid">
          <view
            wx:for="{{preferenceOptions}}"
            wx:key="dictValue"
            class="preference-tag {{preferences.indexOf(item.dictValue) > -1 ? 'preference-tag--active' : ''}}"
            bindtap="onPreferenceTap"
            data-value="{{item.dictValue}}"
          >
            <text class="preference-tag-text">{{item.dictLabel}}</text>
          </view>
        </view>
      </view>

      <!-- Blind Mode -->
      <view class="blind-mode-card">
        <view class="blind-mode-decoration" />
        <view class="blind-mode-content">
          <view class="blind-mode-info">
            <view class="blind-mode-title-row">
              <text class="blind-mode-title">盲游模式</text>
              <view class="blind-mode-badge">
                <text class="blind-mode-badge-text">NEW</text>
              </view>
            </view>
            <text class="blind-mode-desc">让AI在途中为您揭晓意想不到的惊喜点</text>
          </view>
          <view class="blind-mode-toggle">
            <view
              class="toggle-option {{blindMode ? 'toggle-option--active' : ''}}"
              bindtap="onBlindModeSelect"
              data-value="{{true}}"
            >
              <image class="toggle-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-blind-full.svg" mode="aspectFit" />
              <text class="toggle-text {{blindMode ? 'toggle-text--active' : ''}}">全盲惊喜</text>
            </view>
            <view
              class="toggle-option {{!blindMode ? 'toggle-option--active' : ''}}"
              bindtap="onBlindModeSelect"
              data-value="{{false}}"
            >
              <image class="toggle-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-blind-clear.svg" mode="aspectFit" />
              <text class="toggle-text {{!blindMode ? 'toggle-text--active' : ''}}">清晰路径</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Footer -->
  <view class="footer">
    <view class="footer-inner">
      <view class="btn-primary {{loading ? 'btn--disabled' : ''}}" bindtap="onAIPlan">
        <image class="btn-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-target.svg" mode="aspectFit" />
        <text class="btn-primary-text">AI 智能规划</text>
      </view>
      <view class="btn-secondary" bindtap="onManualPlan">
        <text class="btn-secondary-text">自主规划</text>
        <image class="btn-secondary-arrow" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- Loading Overlay -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <view class="loading-spinner" />
      <text class="loading-text">{{progressText || '创建中...'}}</text>
    </view>
  </view>

  <!-- Date Picker Modal -->
  <view wx:if="{{showDatePicker}}" class="date-picker-overlay" bindtap="onCloseDatePicker">
    <view class="date-picker-modal" catchtap="">
      <view class="date-picker-header">
        <text class="date-picker-title">选择出行日期</text>
        <text class="date-picker-confirm" bindtap="onConfirmDate">确定</text>
      </view>
      <view class="date-picker-body">
        <view class="date-picker-row">
          <text class="date-picker-label">开始日期</text>
          <picker mode="date" bindchange="onStartDateChange" value="{{startDate}}">
            <text class="date-picker-value {{startDate ? '' : 'date-placeholder'}}">{{startDate || '请选择'}}</text>
          </picker>
        </view>
        <view class="date-picker-row">
          <text class="date-picker-label">结束日期</text>
          <picker mode="date" bindchange="onEndDateChange" value="{{endDate}}" start="{{startDate}}">
            <text class="date-picker-value {{endDate ? '' : 'date-placeholder'}}">{{endDate || '请选择'}}</text>
          </picker>
        </view>
      </view>
    </view>
  </view>
</view>
