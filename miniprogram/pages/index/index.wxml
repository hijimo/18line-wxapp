<!--index.wxml-->
<wxs src="../../utils/oss.wxs" module="oss" />

<!-- TopAppBar -->
<view class="top-app-bar">
  <view class="top-bar-left">
    <view class="top-bar-avatar">
      <image class="top-bar-avatar-img" src="{{oss.ossResize(userInfo.avatarUrl, 80, 80)}}" mode="aspectFill" />
    </view>
    <text class="top-bar-brand">寻秘</text>
  </view>
  <view class="top-bar-search">
    <image class="top-bar-search-icon" src="/assets/images/icon-search.svg" mode="aspectFit" />
    <text class="top-bar-search-placeholder">寻找神秘之旅...</text>
  </view>
  <view class="top-bar-bell" bindtap="onBellTap">
    <image class="top-bar-bell-icon" src="/assets/images/icon-bell.svg" mode="aspectFit" />
  </view>
</view>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page-main">
    <!-- Section 1: Hero Banner Swiper -->
    <hero-banner banners="{{banners}}" bind:bannertap="onBannerTap" />

    <!-- Section 2: My Journey -->
    <view class="journey-section">
      <view class="journey-section-header">
        <view>
          <view class="journey-section-title">我的寻觅之旅</view>
          <view class="journey-section-subtitle">正在进行的奇遇记</view>
        </view>
        <view class="journey-view-all" bindtap="onViewAll">
          <text class="journey-view-all-text">全部轨迹</text>
        </view>
      </view>

      <block wx:if="{{hasJourneys}}">
        <journey-card journeys="{{journeys}}" bind:viewall="onViewAll" />
      </block>

      <block wx:else>
        <view class="journey-empty-card">
          <view class="journey-empty-icon-wrap">
            <image class="journey-empty-icon" src="/assets/images/icon-empty-journey.svg" mode="aspectFit" />
          </view>
          <text class="journey-empty-text">开启您的第一段寻秘之旅</text>
          <view class="journey-empty-btn" bindtap="onAddTrip">
            <text class="journey-empty-btn-text">去添加</text>
          </view>
        </view>
      </block>
    </view>

    <!-- Section 3: Local Highlights (Inspiration Cards Swiper) -->
    <inspiration-card title="{{inspirationTitle}}" cards="{{inspirationCards}}" bind:cardtap="onInspirationTap" />

    <!-- Section 4: Easter Eggs -->
    <view class="section-eggs">
      <view class="section-heading">
        <text class="section-heading-text">寻找隐匿之物 (Easter Eggs)</text>
      </view>
      <view class="eggs-list">
        <gem-item wx:for="{{eggs}}" wx:key="id" item="{{item}}" bind:itemtap="onEggTap" />
      </view>
    </view>

    <!-- Section 5: Food & Marketplace -->
    <view class="section-food">
      <view class="section-heading">
        <text class="section-heading-text">地道风物 (Delicacies)</text>
      </view>
      <view class="food-grid">
        <food-card wx:for="{{foods}}" wx:key="id" item="{{item}}" bind:cardtap="onFoodTap" />
      </view>
    </view>
  </view>
</scroll-view>
