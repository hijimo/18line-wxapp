<view class="page-container">
  <view class="nav-layer">
    <navigation-bar title="{{itinerary.itineraryName || '行程详情'}}" back="{{true}}" color="black" background="transparent"></navigation-bar>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner" />
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{itinerary}}">
    <!-- 地图区域 -->
    <view class="map-section">
      <map
        class="route-map"
        latitude="{{mapCenter.latitude}}"
        longitude="{{mapCenter.longitude}}"
        scale="{{mapScale}}"
        markers="{{mapMarkers}}"
        polyline="{{mapPolyline}}"
        show-location="{{false}}"
        enable-scroll="{{true}}"
        enable-zoom="{{true}}"
      />
      <view class="map-gradient-overlay" />
    </view>

    <!-- 行程详情浮层 -->
    <view
      class="detail-drawer detail-drawer--{{drawerHeightLevel}} {{drawerDragging ? 'detail-drawer--dragging' : ''}}"
      style="height: {{drawerHeight}}vh;"
      bindtouchstart="onDrawerTouchStart"
      bindtouchmove="onDrawerTouchMove"
      bindtouchend="onDrawerTouchEnd"
      bindtouchcancel="onDrawerTouchEnd"
    >
      <!-- 行程信息卡 -->
      <view
        class="info-card"
        data-drag-scope="handle"
        catchtouchstart="onDrawerTouchStart"
        catchtouchmove="onDrawerTouchMove"
        catchtouchend="onDrawerTouchEnd"
        catchtouchcancel="onDrawerTouchEnd"
      >
        <view class="drawer-handle" aria-role="button" aria-label="拖动调整详情高度">
          <view class="drawer-handle-bar" />
        </view>
        <view class="info-header">
          <text class="info-title">{{itinerary.itineraryName || '未命名行程'}}</text>
          <view class="info-status">
            <text class="info-status-text">{{itinerary.statusLabel || '规划中'}}</text>
          </view>
        </view>
        <view class="info-meta">
          <view class="meta-item">
            <image class="meta-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-distance.svg" mode="aspectFit" />
            <text class="meta-text">{{itinerary.cityName || itinerary.city || ''}}{{(itinerary.districtName || itinerary.district) ? ' · ' + (itinerary.districtName || itinerary.district) : ''}}</text>
          </view>
          <view class="meta-item">
            <image class="meta-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-calendar.svg" mode="aspectFit" />
            <text class="meta-text">{{itinerary.dateRangeText || ''}}</text>
          </view>
        </view>
      </view>

      <!-- Day 导航 -->
      <view class="day-nav-wrapper">
        <scroll-view class="day-nav" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="day-nav-inner">
            <view
              wx:for="{{itinerary.daysList}}"
              wx:key="dayNumber"
              class="day-tab {{currentDay === item.dayNumber ? 'day-tab--active' : ''}}"
              bindtap="onDayTap"
              data-day="{{item.dayNumber}}"
            >
              <text class="day-tab-text">第{{item.dayNumber}}天</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- Timeline 区域 -->
      <scroll-view
        class="scrollarea"
        scroll-y="{{drawerHeightLevel !== 20}}"
        type="list"
        enhanced
        show-scrollbar="{{drawerHeightLevel !== 20}}"
      >
        <view class="timeline" wx:if="{{currentDayData}}">
          <!-- 景点列表 -->
          <block wx:if="{{currentDayData.attractionList && currentDayData.attractionList.length > 0}}">
            <view class="timeline-section">
              <text class="timeline-section-title">景点</text>
              <view class="timeline-cards">
                <attraction-card
                  wx:for="{{currentDayData.attractionList}}"
                  wx:key="attractionId"
                  item="{{item}}"
                  bind:carddetail="onCardDetail"
                />
              </view>
            </view>
          </block>

          <!-- 住宿 -->
          <block wx:if="{{currentDayData.accommodation}}">
            <view class="timeline-section">
              <text class="timeline-section-title">住宿</text>
              <hotel-card item="{{currentDayData.accommodation}}" bind:carddetail="onCardDetail" />
            </view>
          </block>

          <!-- 餐饮 -->
          <block wx:if="{{currentDayData.breakfast || currentDayData.lunch || currentDayData.dinner}}">
            <view class="timeline-section">
              <text class="timeline-section-title">餐饮</text>
              <view class="timeline-cards">
                <dining-card wx:if="{{currentDayData.breakfast}}" item="{{currentDayData.breakfast}}" meal="breakfast" bind:carddetail="onCardDetail" />
                <dining-card wx:if="{{currentDayData.lunch}}" item="{{currentDayData.lunch}}" meal="lunch" bind:carddetail="onCardDetail" />
                <dining-card wx:if="{{currentDayData.dinner}}" item="{{currentDayData.dinner}}" meal="dinner" bind:carddetail="onCardDetail" />
              </view>
            </view>
          </block>

          <!-- 包车 -->
          <block wx:if="{{currentDayData.car}}">
            <view class="timeline-section">
              <text class="timeline-section-title">包车</text>
              <car-card item="{{currentDayData.car}}" bind:carddetail="onCardDetail" />
            </view>
          </block>

          <!-- 跟拍 -->
          <block wx:if="{{currentDayData.photography}}">
            <view class="timeline-section">
              <text class="timeline-section-title">跟拍</text>
              <photography-card item="{{currentDayData.photography}}" bind:carddetail="onCardDetail" />
            </view>
          </block>

          <!-- 添加按钮 -->
          <view wx:if="{{!isTemplate}}" class="add-spot-btn" bindtap="onAddSpot">
            <text class="add-spot-icon">+</text>
            <text class="add-spot-text">添加日程项</text>
          </view>
        </view>

        <!-- 空状态 -->
        <view wx:elif="{{!loading}}" class="empty-day">
          <text class="empty-day-text">当天暂无安排</text>
          <view wx:if="{{!isTemplate}}" class="add-spot-btn" bindtap="onAddSpot">
            <text class="add-spot-icon">+</text>
            <text class="add-spot-text">添加日程项</text>
          </view>
        </view>

        <!-- 地方特色菜 -->
        <view wx:if="{{localSpecialtyList.length > 0}}" class="specialty-section">
          <view class="specialty-header">
            <view class="specialty-heading">
              <text class="specialty-subtitle">CULINARY EXPLORER</text>
              <text class="specialty-title">地方特色菜</text>
            </view>
            <view class="specialty-view-all" style="display:none">
              <text class="specialty-view-all-text">View All</text>
              <text class="specialty-view-all-arrow">›</text>
            </view>
          </view>
          <view class="specialty-list">
            <view wx:for="{{localSpecialtyList}}" wx:key="specialtyId" class="specialty-card">
              <view class="specialty-thumb">
                <image
                  wx:if="{{item.attachments && item.attachments[0] && item.attachments[0].fileUrl}}"
                  class="specialty-thumb-img"
                  src="{{item.attachments[0].fileUrl}}"
                  mode="aspectFill"
                  lazy-load
                />
              </view>
              <view class="specialty-info">
                <text class="specialty-name">{{item.specialtyName}}</text>
                <text wx:if="{{item.specialtyDesc}}" class="specialty-desc">{{item.specialtyDesc}}</text>
                <text wx:if="{{item.price}}" class="specialty-price">¥{{item.price}}/份</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 模板模式底部按钮 -->
      <view wx:if="{{isTemplate}}" class="template-bottom-bar">
        <view class="template-add-btn" bindtap="onAddToMyTrip">
          <text class="template-add-btn-text">添加到我的行程</text>
        </view>
      </view>
    </view>
  </block>

  <!-- Add Schedule Drawer -->
  <add-schedule-drawer
    wx:if="{{showAddDrawer}}"
    show="{{showAddDrawer}}"
    itineraryId="{{itineraryId}}"
    dayNumber="{{addDayNumber}}"
    bind:close="onDrawerClose"
    bind:refresh="onScheduleRefresh"
  />

  <!-- Intro Drawers -->
  <attraction-intro-drawer
    wx:if="{{showIntroDrawer === 'attraction'}}"
    show="{{showIntroDrawer === 'attraction'}}"
    data="{{introData}}"
    bind:close="onIntroClose"
  />
  <hotel-intro-drawer
    wx:if="{{showIntroDrawer === 'hotel'}}"
    show="{{showIntroDrawer === 'hotel'}}"
    data="{{introData}}"
    bind:close="onIntroClose"
  />
  <dining-intro-drawer
    wx:if="{{showIntroDrawer === 'dining'}}"
    show="{{showIntroDrawer === 'dining'}}"
    data="{{introData}}"
    bind:close="onIntroClose"
  />
  <car-intro-drawer
    wx:if="{{showIntroDrawer === 'car'}}"
    show="{{showIntroDrawer === 'car'}}"
    data="{{introData}}"
    bind:close="onIntroClose"
  />
  <photography-intro-drawer
    wx:if="{{showIntroDrawer === 'photography'}}"
    show="{{showIntroDrawer === 'photography'}}"
    data="{{introData}}"
    bind:close="onIntroClose"
  />
</view>
