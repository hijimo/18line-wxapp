<view class="container">
  <navigation-bar title="" back="{{false}}" color="white" background="transparent"></navigation-bar>

  <!-- Background image -->
  <image class="bg-image" src="/assets/images/login-bg.png" mode="aspectFill" />

  <!-- Gradient overlay -->
  <view class="bg-overlay" />

  <!-- Main content -->
  <view class="content-wrapper">
    <!-- Brand identity -->
    <view class="brand-section">
      <view class="logo-container">
        <image class="logo" src="/assets/images/logo.png" mode="aspectFit" />
      </view>
      <view class="brand-name">18线</view>
      <view class="brand-tagline">探索未至之境</view>
    </view>

    <!-- Actions -->
    <view class="actions-section">
      <!-- Main login button -->
      <view class="login-btn {{loading ? 'login-btn--loading' : ''}}" bindtap="handleLogin">
        <image class="wechat-icon" src="/assets/images/icon-wechat.svg" mode="aspectFit" />
        <text class="login-btn-text">{{loading ? '登录中...' : '一键授权登录'}}</text>
      </view>

      <!-- Compliance -->
      <view class="compliance-row">
        <view class="checkbox-container" bindtap="toggleAgreed">
          <view class="checkbox {{agreed ? 'checkbox--checked' : ''}}">
            <image wx:if="{{agreed}}" class="check-icon" src="/assets/images/icon-check-white.svg" mode="aspectFit" />
          </view>
        </view>
        <view class="compliance-text">
          <text>我已阅读并同意 </text>
          <text class="link-text">用户协议</text>
          <text> 和 </text>
          <text class="link-text">隐私政策</text>
          <text>，授权 18线使用您的账号公开信息。</text>
        </view>
      </view>
    </view>
  </view>
</view>
