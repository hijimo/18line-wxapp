<wxs src="../../utils/oss.wxs" module="oss" />
<view class="page-container">
  <navigation-bar title="我的行程" back="{{true}}" color="black" background="#F9FAF4"></navigation-bar>

  <!-- Tabs -->
  <view class="tabs">
    <view class="tab {{currentTab === 'all' ? 'tab--active' : ''}}" bindtap="switchTab" data-tab="all">
      <text class="tab-text">全部</text>
    </view>
    <view class="tab {{currentTab === 'pending' ? 'tab--active' : ''}}" bindtap="switchTab" data-tab="pending">
      <text class="tab-text">待开始</text>
    </view>
    <view class="tab {{currentTab === 'active' ? 'tab--active' : ''}}" bindtap="switchTab" data-tab="active">
      <text class="tab-text">进行中</text>
    </view>
  </view>

  <!-- Trip List -->
  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="trip-list">
      <block wx:if="{{trips.length > 0}}">
        <view class="trip-card" wx:for="{{trips}}" wx:key="id" bindtap="onTripTap" data-id="{{item.id}}">
          <view class="trip-card-header">
            <view class="trip-status trip-status--{{item.statusClass}}">
              <view class="status-dot status-dot--{{item.statusClass}}" />
              <text class="status-text">{{item.statusLabel}}</text>
            </view>
            <text class="trip-date">{{item.date}}</text>
          </view>
          <view class="trip-card-body">
            <image class="trip-cover" src="{{oss.ossResize(item.image, 160, 160)}}" mode="aspectFill" />
            <view class="trip-info">
              <text class="trip-title">{{item.title}}</text>
              <text class="trip-desc">{{item.description}}</text>
              <view class="trip-meta">
                <view class="meta-item">
                  <image class="meta-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-calendar.svg" mode="aspectFit" />
                  <text class="meta-text">{{item.days}}天</text>
                </view>
              </view>
            </view>
          </view>
          <!-- Day Progress -->
          <view wx:if="{{item.phase === 'active'}}" class="day-progress">
            <view class="day-item {{day.status}}" wx:for="{{item.days_detail}}" wx:for-item="day" wx:key="day">
              <view class="day-dot" />
              <text class="day-label">DAY {{day.day}}</text>
            </view>
            <view class="progress-line" />
          </view>
        </view>
      </block>
      <view wx:else class="empty-state">
        <image class="empty-icon" src="https://travel18.oss-cn-hangzhou.aliyuncs.com/assets/images/icon-calendar.svg" mode="aspectFit" />
        <text class="empty-title">暂无行程</text>
        <text class="empty-desc">去探索页面开启一段新旅程吧</text>
      </view>
    </view>
  </scroll-view>
</view>
