      </view>-->

      <!-- Functional List -->
      <view class="func-card">
        <view class="func-item" bindtap="goTravelTraits">
          <view class="func-item-left">
            <view class="func-icon-wrap func-icon-wrap--green">
              <image class="func-icon" src="/assets/images/icon-travel-trait.svg" mode="aspectFit" />
            </view>
            <view class="func-text-wrap">
              <text class="func-title">我的旅游特性</text>
              <text class="func-subtitle">分析您的探险风格与偏好</text>
            </view>
          </view>
          <image class="func-arrow" src="/assets/images/icon-chevron-right.svg" mode="aspectFit" />
        </view>
        <view class="func-divider" />
        <view class="func-item" bindtap="goFAQ">
          <view class="func-item-left">
            <view class="func-icon-wrap func-icon-wrap--grey">
              <image class="func-icon" src="/assets/images/icon-faq.svg" mode="aspectFit" />
            </view>
            <view class="func-text-wrap">
              <text class="func-title">常见问题</text>
              <text class="func-subtitle">获取帮助与系统支持</text>
            </view>
          </view>
          <image class="func-arrow" src="/assets/images/icon-chevron-right.svg" mode="aspectFit" />
        </view>
      </view>

      <!-- Logout Button -->
      <view class="logout-btn" bindtap="handleLogout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </scroll-view>

</view>
