{
  "name": "18line-wxapp-e2e-tests",
  "version": "1.0.0",
  "description": "微信小程序 e2e 自动化测试",
  "scripts": {
    "test:e2e:auth": "jest --config jest.e2e.auth.config.js --runInBand --forceExit",
    "test:e2e:smoke": "jest --config jest.e2e.smoke.config.js --runInBand --forceExit",
    "test:e2e:core": "jest --config jest.e2e.core.config.js --runInBand --forceExit",
    "test:e2e:regression": "jest --config jest.e2e.regression.config.js --runInBand --forceExit",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand --forceExit",
    "test:home-unit": "jest --config jest.config.js --testMatch \"**/home/**/*.unit.test.js\" --runInBand --forceExit",
    "test:all": "npm run test:e2e"
  },
  "devDependencies": {
    "miniprogram-automator": "^0.12.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12"
  }
}
